        { label: 'Contacts', data: ts.map(d=>d.contacts), backgroundColor: C.cyan+'99', borderColor: C.cyan, borderWidth: 1, yAxisID: 'yContacts' },
        { label: 'DPC ($)', data: ts.map(d=>d.dpc), type: 'line', borderColor: C.amber, backgroundColor: 'transparent', borderWidth: 2, pointRadius: 2, tension: 0.3, yAxisID: 'yDPC' }
      ]
    },
