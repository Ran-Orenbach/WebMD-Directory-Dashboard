          borderWidth: 2,
          borderDash: [5,4],
          pointRadius: 0,
          fill: false
        }
      ]
    },
    options: {
      ...CD,
      plugins: {
        ...CD.plugins,
        tooltip: {
          ...CD.plugins.tooltip,
          callbacks: {
            label: ctx => {
              const d = ctx.raw;
              return d.month ? `${d.month}: ${d.x?.toFixed(1)} contacts/prof, ${d.y?.toFixed(1)}% ann. total churn` : `(${d.x?.toFixed(1)}, ${d.y?.toFixed(1)})%`;
            }
          }
        }
      },
      scales: {
        x: { ...CD.scales.x, title: { display: true, text: 'Contacts per Profile', color: '#94a3b8', font:{size:11} }, ticks: { color: '#64748b', font:{size:10} } },
        y: { ...CD.scales.y, title: { display: true, text: 'Annual Cancel Rate (%)', color: '#94a3b8', font:{size:11} }, ticks: { color: '#64748b', font:{size:10}, callback: v => v+'%' } }
      }
    }
  });

  // DPC by segment grouped bar
  const tierData = CD2.dpc_by_tier;
  const rangeData = CD2.dpc_by_range;
  const segLabels = [...tierData.map(d=>d.segment), ...rangeData.map(d=>d.segment)];
  const segDPC = [...tierData.map(d=>d.dpc), ...rangeData.map(d=>d.dpc)];
