function buildTables(){
  const tb=document.getElementById('mrr-table-body');
  D.waterfall.slice(1).forEach(d=>{
    const net=d.ending_mrr-d.starting_mrr;
    const cpRaw=d.total_churn_pct||0; const cp=cpRaw?(cpRaw*12).toFixed(1)+'%':'-';
    const r=document.createElement('tr');
    r.innerHTML=`<td>${d.month}</td><td class="num">${fmt(d.starting_mrr)}</td><td class="num" style="color:var(--positive)">+${fmt(d.new_mrr)}</td><td class="num" style="color:var(--accent)">+${fmt(d.expansion)}</td><td class="num" style="color:var(--accent3)">${fmt(d.contraction)}</td><td class="num" style="color:var(--negative)">${fmt(d.churned)}</td><td class="num"><strong>${fmt(d.ending_mrr)}</strong></td><td class="num" style="color:${net>=0?'var(--positive)':'var(--negative)'}">${net>=0?'+':''}${fmt(net)}</td><td class="num" style="color:${parseFloat(cp)>6?'var(--negative)':'var(--text2)'}">${cp}%</td>`;
    tb.appendChild(r);
  });
  const totalRev=D.arpc_by_tier.reduce((s,d)=>s+d.revenue,0);
  const tierColors={'Tier 1':'badge-t1','Tier 2':'badge-t2','Tier 3':'badge-t3','Tier 4':'badge-t4','Multi Specialty':'badge-ms'};
  const tierTb=document.getElementById('tier-table-body');
  D.arpc_by_tier.forEach(d=>{
    const share=(d.revenue/totalRev*100).toFixed(1);
    const r=document.createElement('tr');
    r.innerHTML=`<td><span class="badge ${tierColors[d.tier]}">${d.tier}</span></td><td class="num">${d.profiles.toLocaleString()}</td><td class="num">${d.accounts.toLocaleString()}</td><td class="num">${fmt(d.revenue)}</td><td class="num"><strong>${fmt(d.arpc)}</strong></td><td class="num">${fmt(d.arpc_account)}</td><td><div style="display:flex;align-items:center;gap:8px"><div style="width:${Math.round(parseFloat(share)*3)}px;height:6px;background:${TC[d.tier]||C.blue};border-radius:3px;max-width:120px"></div><span style="color:var(--text2)">${share}%</span></div></td>`;
    tierTb.appendChild(r);
  });
  const totalRevR=D.arpc_by_range.reduce((s,d)=>s+d.revenue,0);
  const rangeTb=document.getElementById('range-table-body');
  D.arpc_by_range.forEach(d=>{
    const share=(d.revenue/totalRevR*100).toFixed(1);
    const r=document.createElement('tr');
    r.innerHTML=`<td><span class="badge" style="background:${RC[d.range]}22;color:${RC[d.range]}">${d.range}</span></td><td class="num">${d.profiles.toLocaleString()}</td><td class="num">${d.accounts.toLocaleString()}</td><td class="num">${fmt(d.revenue)}</td><td class="num"><strong>${fmt(d.arpc)}</strong></td><td><div style="display:flex;align-items:center;gap:8px"><div style="width:${Math.round(parseFloat(share)*2)}px;height:6px;background:${RC[d.range]};border-radius:3px;max-width:120px"></div><span style="color:var(--text2)">${share}%</span></div></td>`;
    rangeTb.appendChild(r);
  });
  const aopTb=document.getElementById('aop-table-body');
  D.top_aops.forEach((d,i)=>{
    const r=document.createElement('tr');
    r.innerHTML=`<td style="color:var(--text3)">${i+1}</td><td><strong>${d.aop}</strong></td><td class="num">${fmt(d.revenue_6m)}</td><td class="num">${d.profiles.toLocaleString()}</td><td class="num">${d.accounts.toLocaleString()}</td><td class="num" style="color:${d.arpc>150?'var(--positive)':'var(--text)'}">${fmt(d.arpc)}</td>`;
    aopTb.appendChild(r);
  });
}

function getColor(v){
  if(v===null)return'transparent';
  if(v>150)return'rgba(167,139,250,0.4)';
  if(v>=100)return'rgba(52,211,153,0.35)';
  if(v>=80)return'rgba(52,211,153,0.2)';
  if(v>=60)return'rgba(245,158,11,0.25)';
  if(v>=40)return'rgba(248,113,113,0.2)';
  if(v>=20)return'rgba(248,113,113,0.35)';
  return'rgba(248,113,113,0.5)';
}

function renderCohorts(){
  const f=document.getElementById('cohort-from').value;
  let cohorts=D.cohort_retention;
  if(f==='2023')cohorts=cohorts.filter(c=>c.cohort.startsWith('2023')||c.cohort==='Pre-2023');
  else if(f==='2024')cohorts=cohorts.filter(c=>c.cohort.startsWith('2024')||c.cohort.startsWith('2025'));
  else if(f==='2025')cohorts=cohorts.filter(c=>c.cohort.startsWith('2025'));
  const maxM=13;
  let html='<table><thead><tr><th>Cohort</th><th>Initial $</th>';
  for(let m=0;m<maxM;m++)html+=`<th>M${m}</th>`;
  html+='</tr></thead><tbody>';
  cohorts.forEach(c=>{
    html+=`<tr><td style="color:var(--text2);white-space:nowrap;padding:4px 8px;font-weight:600">${c.cohort}</td><td style="color:var(--text3);white-space:nowrap;padding:4px 8px">${fmtK(c.m0)}</td>`;
    for(let m=0;m<maxM;m++){
      const v=c.retention[m];
      const dv=v!==null?Math.round(v)+'%':'';
      html+=`<td style="background:${getColor(v)};color:${v!==null?'var(--text)':'transparent'}">${dv}</td>`;
    }
    html+='</tr>';
  });
  html+='</tbody></table>';
  document.getElementById('cohort-heatmap').innerHTML=html;
  const avg=[];
  for(let m=0;m<maxM;m++){
    const vals=cohorts.map(c=>c.retention[m]).filter(v=>v!==null&&v<=150);
    avg.push(vals.length>0?vals.reduce((a,b)=>a+b,0)/vals.length:null);
  }
  if(window.retChart)window.retChart.destroy();
  window.retChart=new Chart(document.getElementById('chart-retention-avg'),{type:'line',data:{labels:avg.map((_,i)=>'M'+i),datasets:[{label:'Avg Retention %',data:avg,borderColor:C.blue,backgroundColor:'rgba(79,142,247,0.08)',borderWidth:2.5,fill:true,tension:0.3,pointRadius:4,pointBackgroundColor:C.blue}]},options:{...CD,scales:{x:CD.scales.x,y:{...CD.scales.y,min:0,max:110,ticks:{callback:v=>v+'%'}}}}});
}

