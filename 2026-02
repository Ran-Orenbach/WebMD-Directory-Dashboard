const fmt=v=>'$'+Math.round(v).toLocaleString();
const ann = p => p === null || p === undefined ? null : parseFloat((p * 12).toFixed(1));

const fmtK=v=>'$'+(Math.round(v/1000))+'K';
const pct=v=>v.toFixed(1)+'%';
const C={blue:'#4f8ef7',green:'#34d399',amber:'#f59e0b',red:'#f87171',purple:'#a78bfa',cyan:'#22d3ee',pink:'#f472b6',lime:'#84cc16'};
const TC={'Tier 1':C.purple,'Tier 2':C.blue,'Tier 3':C.green,'Tier 4':C.amber,'Multi Specialty':C.pink};
const RC={'$0-$75':C.purple,'$75-$150':C.blue,'$150-$300':C.green,'$300+':C.amber};
const CD={responsive:true,animation:{duration:400},plugins:{legend:{labels:{color:'#94a3b8',font:{size:11},boxWidth:12,padding:10}},tooltip:{backgroundColor:'#1a1d27',titleColor:'#e2e8f0',bodyColor:'#94a3b8',borderColor:'#2e3350',borderWidth:1,padding:10}},scales:{x:{ticks:{color:'#64748b',font:{size:10},maxRotation:45},grid:{color:'#1e2235'}},y:{ticks:{color:'#64748b',font:{size:10}},grid:{color:'#1e2235'}}}};

function showPage(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  btn.classList.add('active');
}

function buildKPIs(){
  const last=D.mrr_timeseries[D.mrr_timeseries.length-1];
  const prev=D.mrr_timeseries[D.mrr_timeseries.length-2];
  const la=D.active_accounts[D.active_accounts.length-1];
  const pa=D.active_accounts[D.active_accounts.length-2];
  const lc=D.churn_rates[D.churn_rates.length-1];
  const lw=D.waterfall[D.waterfall.length-1];
  const mrrD=((last.mrr-prev.mrr)/prev.mrr*100).toFixed(1);
  const profD=la.profiles-pa.profiles;
  const arpcD=(la.arpc-pa.arpc).toFixed(0);
  document.getElementById('kpis').innerHTML=`
    <div class="kpi"><div class="label">Ending MRR (Feb '26)</div><div class="value">${fmtK(last.mrr)}</div><div class="delta ${last.mrr>prev.mrr?'up':'down'}">${mrrD>0?'+':''}${mrrD}% vs prior</div></div>\n    <div class="kpi"><div class="label">Active EP Profiles</div><div class="value">${la.profiles.toLocaleString()}</div><div class="delta ${profD>=0?'up':'down'}">${profD>=0?'+':''}${profD} vs prior</div><div class="sub">${la.accounts.toLocaleString()} accounts</div></div>\n    <div class="kpi"><div class="label">Rev / Profile (EP)</div><div class="value">${fmt(la.arpc)}</div><div class="delta ${arpcD>=0?'up':'down'}">${arpcD>=0?'+':''}$${arpcD} vs prior</div><div class="sub">${fmt(la.arpc_account)}/account</div></div>\n    <div class="kpi"><div class="label">Annual Cancel Rate (Feb '26)</div><div class="value" style="color:var(--negative)">${pct(ann(lc.total_churn_pct))}</div><div class="sub">Annualized (monthly ×12)</div></div>
    <div class="kpi"><div class="label">New MRR (Feb '26)</div><div class="value" style="color:var(--positive)">${fmtK(lw.new_mrr)}</div><div class="sub">New logo revenue</div></div>\n    <div class="kpi"><div class="label">Churned MRR (Feb '26)</div><div class="value" style="color:var(--negative)">${fmtK(Math.abs(lw.churned))}</div><div class="sub">Full cancellations</div></div>
    <div class="kpi"><div class="label">Peak Active Profiles</div><div class="value">6,674</div><div class="sub">Oct 2025</div></div>
  `;
  const ytd=D.waterfall.filter(d=>d.month.startsWith('2026'));
  const ytdNew=ytd.reduce((s,d)=>s+d.new_mrr,0);
  const ytdChurn=ytd.reduce((s,d)=>s+Math.abs(d.churned),0);
  const wf01=D.waterfall.find(d=>d.month==='2026-01');
  document.getElementById('mrr-kpis').innerHTML=`
    <div class="kpi"><div class="label">Starting MRR 2026</div><div class="value">${fmtK(wf01.starting_mrr)}</div></div>
    <div class="kpi"><div class="label">YTD New MRR</div><div class="value" style="color:var(--positive)">${fmtK(ytdNew)}</div><div class="sub">2 months</div></div>
    <div class="kpi"><div class="label">YTD Churned</div><div class="value" style="color:var(--negative)">${fmtK(ytdChurn)}</div></div>
    <div class="kpi"><div class="label">Net MRR YTD</div><div class="value" style="color:var(--negative)">${fmtK(last.mrr-wf01.starting_mrr)}</div></div>
    <div class="kpi"><div class="label">Avg New MRR/Mo (2025)</div><div class="value">${fmtK(D.waterfall.filter(d=>d.month.startsWith('2025')).reduce((s,d)=>s+d.new_mrr,0)/12)}</div></div>
    <div class="kpi"><div class="label">Avg Churn/Mo (2025)</div><div class="value">${fmtK(D.waterfall.filter(d=>d.month.startsWith('2025')).reduce((s,d)=>s+Math.abs(d.churned),0)/12)}</div></div>
  `;
}

function buildCharts(){
  const labels=D.mrr_timeseries.map(d=>d.month.slice(2));
  new Chart(document.getElementById('chart-mrr-main'),{type:'line',data:{labels,datasets:[{label:'MRR',data:D.mrr_timeseries.map(d=>d.mrr),borderColor:C.blue,backgroundColor:'rgba(79,142,247,0.08)',borderWidth:2,fill:true,tension:0.3,pointRadius:2}]},options:{...CD,scales:{x:CD.scales.x,y:{...CD.scales.y,ticks:{...CD.scales.y.ticks,callback:v=>fmtK(v)}}}}});
  const wf12=D.waterfall.slice(-13);
  new Chart(document.getElementById('chart-waterfall-bar'),{type:'bar',data:{labels:wf12.map(d=>d.month.slice(2)),datasets:[{label:'New MRR',data:wf12.map(d=>d.new_mrr),backgroundColor:C.green},{label:'Expansion',data:wf12.map(d=>d.expansion),backgroundColor:C.blue},{label:'Contraction',data:wf12.map(d=>d.contraction),backgroundColor:C.amber},{label:'Churn',data:wf12.map(d=>d.churned),backgroundColor:C.red}]},options:{...CD,scales:{x:{...CD.scales.x,stacked:true},y:{...CD.scales.y,stacked:true,ticks:{callback:v=>fmtK(v)}}}}});
