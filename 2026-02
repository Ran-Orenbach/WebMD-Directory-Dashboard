        { label: 'DPC ($)', data: aopData.map(d=>d.dpc), backgroundColor: C.green+'cc', xAxisID: 'xDPC' },
        { label: 'Contacts', data: aopData.map(d=>d.contacts), type: 'bar', backgroundColor: C.blue+'55', xAxisID: 'xContacts' }
      ]
    },
    options: { ...CD, indexAxis: 'y', scales: {
      y: { ...CD.scales.y, ticks:{color:'#94a3b8',font:{size:10}} },
      xDPC: { position:'top', ticks:{color:C.green,font:{size:10},callback:v=>'$'+v}, grid:{color:'#1e2235'}, title:{display:true,text:'DPC ($)',color:C.green,font:{size:10}} },
      xContacts: { position:'bottom', ticks:{color:C.blue,font:{size:10},callback:v=>v.toLocaleString()}, grid:{display:false}, title:{display:true,text:'Contacts',color:C.blue,font:{size:10}} }
