  const segColors = [C.purple, C.blue, C.green, C.amber, C.purple+'99', C.blue+'99', C.green+'99', C.amber+'99'];

  new Chart(document.getElementById('chart-dpc-seg'), {
    type: 'bar',
    data: {
      labels: segLabels,
      datasets: [
        { label: 'DPC ($)', data: segDPC, backgroundColor: segColors, yAxisID: 'yDPC' },
        { label: 'Contacts/Profile', data: segCPP, type: 'line', borderColor: C.cyan, backgroundColor:'transparent', borderWidth: 2, pointRadius: 4, pointBackgroundColor: C.cyan, yAxisID: 'yCPP' }
      ]
    },
    options: { ...CD, scales: {
      x: { ...CD.scales.x, ticks: { color:'#94a3b8', font:{size:10}, maxRotation:35 } },
      yDPC: { position: 'left', ticks: { color: C.amber, font:{size:10}, callback: v=>'$'+v }, grid:{color:'#1e2235'}, title:{display:true,text:'DPC ($)',color:C.amber,font:{size:10}} },
      yCPP: { position: 'right', ticks: { color: C.cyan, font:{size:10} }, grid:{display:false}, title:{display:true,text:'Contacts/Profile',color:C.cyan,font:{size:10}} }
    }}
  });

  // DPC by AOP horizontal bar
  const aopData = CD2.dpc_by_aop.slice(0,15);
  new Chart(document.getElementById('chart-dpc-aop'), {
    type: 'bar',
    data: {
