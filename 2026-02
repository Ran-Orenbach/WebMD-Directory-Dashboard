function buildContactsKPIs() {
  const ts = CD2.contacts_ts;
  const last = ts[ts.length - 1];
  const prev = ts[ts.length - 2];
  const peak = ts.reduce((a,b) => b.contacts > a.contacts ? b : a);
  const lastDPC = last.dpc || 0;
  const prevDPC = prev.dpc || 0;
  const dpcDelta = (lastDPC - prevDPC).toFixed(2);
  const contactDelta = last.contacts - prev.contacts;

  // avg DPC last 6 months
  const last6 = ts.slice(-6).filter(d=>d.dpc);
  const avgDPC = last6.reduce((s,d)=>s+d.dpc,0)/last6.length;

  document.getElementById('contacts-kpis').innerHTML = `
    <div class="kpi"><div class="label">Contacts (Jan '26)</div><div class="value">${last.contacts.toLocaleString()}</div><div class="delta ${contactDelta>=0?'up':'down'}">${contactDelta>=0?'+':''}${contactDelta.toLocaleString()} vs prior</div></div>\n    <div class="kpi"><div class="label">DPC — Jan '26</div><div class="value">$${lastDPC.toFixed(2)}</div><div class="delta ${dpcDelta>=0?'down':'up'}">${dpcDelta>=0?'▲':'▼'}$${Math.abs(dpcDelta)} vs prior</div><div class="sub">Higher DPC = fewer contacts per $</div></div>
    <div class="kpi"><div class="label">Avg DPC (last 6 mo)</div><div class="value">$${avgDPC.toFixed(2)}</div><div class="sub">vs $21–24 in 2023-24</div></div>
    <div class="kpi"><div class="label">Peak Contacts</div><div class="value">${peak.contacts.toLocaleString()}</div><div class="sub">${peak.month}</div></div>
    <div class="kpi"><div class="label">Contact Decline</div><div class="value" style="color:var(--negative)">−45%</div><div class="sub">Peak → Jun/Jul 2025</div></div>
    <div class="kpi"><div class="label">Correlation (cpp vs ann. total churn)</div><div class="value">+0.40</div><div class="sub">Moderate positive — see analysis</div></div>
  `;
}

function buildContactsCharts() {
  const ts = CD2.contacts_ts;
  const labels = ts.map(d => d.month.slice(2));

  // Contacts timeseries + DPC dual axis
  new Chart(document.getElementById('chart-contacts-ts'), {
