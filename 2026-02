      labels: bracketLabels,
      datasets: [
        { label: 'High Demand', data: highPrices,  backgroundColor: 'rgba(52,211,153,0.7)',  borderRadius: 4 },
        { label: 'Standard',    data: stdPrices,   backgroundColor: 'rgba(79,142,247,0.7)',  borderRadius: 4 },
        { label: 'Low Demand',  data: lowPrices,   backgroundColor: 'rgba(100,116,139,0.5)', borderRadius: 4 }
      ]
    },
    options: {
      ...CD,
      scales: {
        x: { ...CD.scales.x, ticks: { color:'#64748b', font:{size:10} } },
        y: { ...CD.scales.y, ticks: { color:'#64748b', font:{size:10}, callback: v=>'$'+v } }
      }
    }
  });

  // ── impact table ──────────────────────────────────────────────────────────
  const impTbody = document.getElementById('impact-tbody');
  const gainRows = PM.matrix.filter(c=>c.uplift>0).sort((a,b)=>b.uplift-a.uplift);
  gainRows.forEach(c => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${c.bracket} · <span style="color:${c.demand==='High'?'#34d399':c.demand==='Standard'?'#4f8ef7':'#64748b'}">${c.demand} demand</span></td>
      <td class="num">${c.accts}</td><td class="num">${c.profiles.toLocaleString()}</td>
      <td class="num">${fmt(c.cur_rev)}</td>
      <td class="num">${fmt(c.new_rev)}</td>
      <td class="num" style="color:var(--positive);font-weight:700">+${fmt(c.uplift)}</td>
      <td class="num" style="color:var(--positive)">+${fmt(c.uplift*0.7)}</td>`;
    impTbody.appendChild(tr);
  });

  // totals row
  const trT = document.createElement('tr');
  trT.style.fontWeight = '700'; trT.style.borderTop = '2px solid var(--border)';
  const totCur = gainRows.reduce((s,c)=>s+c.cur_rev,0);
  const totNew = gainRows.reduce((s,c)=>s+c.new_rev,0);
  const totUp  = gainRows.reduce((s,c)=>s+c.uplift,0);
  trT.innerHTML = `<td>TOTAL (raise segments only)</td>
    <td class="num">${gainRows.reduce((s,c)=>s+c.accts,0)}</td>
    <td class="num">${gainRows.reduce((s,c)=>s+c.profiles,0).toLocaleString()}</td>
    <td class="num">${fmt(totCur)}</td><td class="num">${fmt(totNew)}</td>
    <td class="num" style="color:var(--positive)">+${fmt(totUp)}</td>
    <td class="num" style="color:var(--positive)">+${fmt(totUp*0.7)}</td>`;
  impTbody.appendChild(trT);
}
buildPricingPage();
</script>
</body>
</html>
