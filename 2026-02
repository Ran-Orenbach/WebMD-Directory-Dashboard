    }}
  });

  // Contacts/profile vs cancel rate dual line
  const churnLookup = {};
  D.churn_rates.forEach(d => { churnLookup[d.month] = d.total_churn_pct; });
  const tsWithChurn = ts.map(d => ({...d, total_churn_pct: churnLookup[d.month] || null}));
  const validTs = tsWithChurn.filter(d => d.contacts_per_profile && d.total_churn_pct);
  new Chart(document.getElementById('chart-cpp-churn'), {
    type: 'line',
    data: {
      labels: validTs.map(d => d.month.slice(2)),
      datasets: [
        { label: 'Contacts/Profile', data: validTs.map(d=>d.contacts_per_profile), borderColor: C.cyan, backgroundColor: 'rgba(34,211,238,0.07)', fill: true, borderWidth: 2, tension: 0.3, pointRadius: 2, yAxisID: 'yCPP' },
        { label: 'Annual Total Churn %', data: validTs.map(d=>ann(d.total_churn_pct)), borderColor: C.red, backgroundColor: 'transparent', borderWidth: 2, tension: 0.3, pointRadius: 2, borderDash: [4,3], yAxisID: 'yChurn' }
      ]
    },
    options: { ...CD, scales: {
      x: CD.scales.x,
      yCPP: { position: 'left', ticks: { color: C.cyan, font: {size:10}, callback: v => v.toFixed(1) }, grid: { color: '#1e2235' }, title: { display: true, text: 'Contacts/Profile', color: C.cyan, font: {size:10} } },
      yChurn: { position: 'right', ticks: { color: C.red, font: {size:10}, callback: v => v+'%' }, grid: { display: false }, title: { display: true, text: 'Cancel %', color: C.red, font: {size:10} } }
    }}
  });

  // Scatter: contacts/profile vs churn
  const scatterData = CD2.scatter.map(d => ({ x: d.cpp, y: ann(churnLookup[d.month]||d.cancel_pct), month: d.month }));
  // Add trend line
  const xs = scatterData.map(d=>d.x), ys = scatterData.map(d=>d.y);
  const n = xs.length;
  const sx = xs.reduce((a,b)=>a+b,0), sy = ys.reduce((a,b)=>a+b,0);
  const sxy = xs.reduce((a,b,i)=>a+b*ys[i],0), sx2 = xs.reduce((a,b)=>a+b*b,0);
  const slope = (n*sxy - sx*sy)/(n*sx2 - sx*sx);
  const intercept = (sy - slope*sx)/n;
  const xMin = Math.min(...xs), xMax = Math.max(...xs);
  const trendData = [{x:xMin, y:intercept+slope*xMin},{x:xMax, y:intercept+slope*xMax}];

  new Chart(document.getElementById('chart-scatter'), {
    type: 'scatter',
    data: {
      datasets: [
        {
          label: 'Monthly data point',
