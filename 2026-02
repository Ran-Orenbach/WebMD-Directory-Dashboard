function buildPricingPage() {
  const vol_order = ['Solo (1)','Small (2)','Group (3–5)','Mid (6–10)',
    'Large (11–25)','Regional (26–50)','Enterprise (51–200)','Strategic (201+)'];
  const dem_order = ['High','Standard','Low'];
  const dem_colors = {
    'High':   {bg:'rgba(52,211,153,0.08)',  col:'#34d399'},
    'Standard':{bg:'rgba(79,142,247,0.06)', col:'#4f8ef7'},
    'Low':    {bg:'rgba(100,116,139,0.06)', col:'#94a3b8'}
  };

  // ── matrix table ──────────────────────────────────────────────────────────
  const tbody = document.getElementById('pricing-matrix-tbody');
  vol_order.forEach(vb => {
    const row_cells = {};
    let total_accts = 0, total_profs = 0;
    dem_order.forEach(dem => {
      const cell = PM.matrix.find(c => c.bracket===vb && c.demand===dem);
      row_cells[dem] = cell;
      if (cell) { total_accts += cell.accts; total_profs += cell.profiles; }
    });

    const tr = document.createElement('tr');
    let uplift_total = 0;

    // volume bracket cell
    const tdVol = document.createElement('td');
    tdVol.innerHTML = `<strong>${vb}</strong>`;
    tr.appendChild(tdVol);

    const tdA = document.createElement('td'); tdA.className='num'; tdA.textContent = total_accts; tr.appendChild(tdA);
    const tdP = document.createElement('td'); tdP.className='num'; tdP.textContent = total_profs.toLocaleString(); tr.appendChild(tdP);

    dem_order.forEach(dem => {
      const td = document.createElement('td');
      td.className = 'num';
      td.style.background = dem_colors[dem].bg;
      const cell = row_cells[dem];
      if (!cell) { td.innerHTML = '<span style="color:var(--text3)">—</span>'; tr.appendChild(td); return; }

      const isHold = cell.uplift < 0;
      const arrow = isHold ? '=' : '↑';
      const arrowColor = isHold ? 'var(--text3)' : 'var(--positive)';
      const priceStyle = isHold ? 'color:var(--text3);font-style:italic' : `color:${dem_colors[dem].col};font-weight:700`;

      td.innerHTML = `
        <span style="${priceStyle}">$${cell.new_price}/prof</span><br>
