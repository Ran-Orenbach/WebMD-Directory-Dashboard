<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WebMD Directory — Revenue Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root{--bg:#0f1117;--surface:#1a1d27;--surface2:#22263a;--border:#2e3350;--accent:#4f8ef7;--accent2:#34d399;--accent3:#f59e0b;--accent4:#f87171;--accent5:#a78bfa;--text:#e2e8f0;--text2:#94a3b8;--text3:#64748b;--positive:#34d399;--negative:#f87171}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;font-size:13px;min-height:100vh}
  header{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
  header h1{font-size:17px;font-weight:700;color:var(--text);letter-spacing:-.3px}
  header span{font-size:12px;color:var(--text3);background:var(--surface2);border:1px solid var(--border);padding:4px 10px;border-radius:20px}
  nav{background:var(--surface);border-bottom:1px solid var(--border);display:flex;gap:2px;padding:0 24px;overflow-x:auto}
  nav button{background:none;border:none;color:var(--text2);font-size:13px;padding:12px 16px;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
  nav button:hover{color:var(--text)}
  nav button.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600}
  .page{display:none;padding:24px 28px;max-width:1400px;margin:0 auto}
  .page.active{display:block}
  .kpi-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:22px}
  .kpi{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 18px}
  .kpi .label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
  .kpi .value{font-size:24px;font-weight:700;color:var(--text);line-height:1}
  .kpi .sub{font-size:11px;color:var(--text3);margin-top:5px}
  .kpi .delta{font-size:12px;font-weight:600;margin-top:4px}
  .kpi .delta.up{color:var(--positive)}.kpi .delta.down{color:var(--negative)}
  .grid{display:grid;gap:16px}
  .grid-2{grid-template-columns:1fr 1fr}.grid-3{grid-template-columns:1fr 1fr 1fr}.grid-2-1{grid-template-columns:2fr 1fr}
  .card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px 20px}
  .card-title{font-size:13px;font-weight:600;color:var(--text);margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}
  .card-title span{font-size:11px;font-weight:400;color:var(--text3)}
  .chart-wrap{position:relative}
  .filter-bar{display:flex;gap:10px;align-items:center;margin-bottom:18px;flex-wrap:wrap}
  .filter-bar label{font-size:11px;color:var(--text3);margin-right:4px}
  .filter-bar select{background:var(--surface2);border:1px solid var(--border);color:var(--text);font-size:12px;padding:5px 10px;border-radius:6px;cursor:pointer}
  .table-wrap{overflow-x:auto}
  table{width:100%;border-collapse:collapse;font-size:12px}
  th{color:var(--text3);font-weight:600;text-align:left;padding:8px 12px;border-bottom:1px solid var(--border);font-size:11px;text-transform:uppercase;letter-spacing:.4px;white-space:nowrap}
  td{padding:7px 12px;border-bottom:1px solid var(--border);color:var(--text)}
  tr:last-child td{border-bottom:none}
  tr:hover td{background:var(--surface2)}
  td.num{text-align:right;font-variant-numeric:tabular-nums}
  .badge{padding:2px 8px;border-radius:12px;font-size:11px;font-weight:600}
  .badge-t1{background:rgba(167,139,250,.15);color:#a78bfa}
  .badge-t2{background:rgba(79,142,247,.15);color:#4f8ef7}
  .badge-t3{background:rgba(52,211,153,.15);color:#34d399}
  .badge-t4{background:rgba(245,158,11,.15);color:#f59e0b}
  .badge-ms{background:rgba(244,114,182,.15);color:#f472b6}
  .cohort-table{overflow-x:auto}
  .cohort-table table{font-size:11px}
  .cohort-table td{padding:4px 6px;text-align:center;min-width:38px;border-radius:3px;font-size:10px;font-weight:600}
  .cohort-table th{padding:4px 6px;text-align:center;font-size:10px}
  .pricing-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px}
  .pricing-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px;position:relative}
  .pricing-card.highlight{border-color:var(--accent)}
  .pricing-card .tier-badge{font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px}
  .pricing-card .tier-price{font-size:28px;font-weight:800;color:var(--text);margin-bottom:4px}
  .pricing-card .tier-price sup{font-size:14px;font-weight:400}
  .pricing-card .tier-price sub{font-size:13px;font-weight:400;color:var(--text2)}
  .pricing-card .tier-desc{font-size:12px;color:var(--text2);margin-bottom:12px}
  .pricing-card ul{list-style:none}
  .pricing-card ul li{font-size:12px;color:var(--text2);padding:4px 0;border-bottom:1px solid var(--border);display:flex;gap:6px}
  .pricing-card ul li:last-child{border-bottom:none}
  .pricing-card ul li::before{content:'✓';color:var(--positive);font-size:11px;margin-top:1px}
  .rec-badge{position:absolute;top:-10px;right:14px;background:var(--accent);color:white;font-size:10px;font-weight:700;padding:3px 10px;border-radius:12px}
  .insight-box{background:var(--surface2);border-left:3px solid var(--accent);border-radius:0 8px 8px 0;padding:12px 16px;margin-bottom:12px;font-size:12px;line-height:1.6;color:var(--text2)}
  .insight-box strong{color:var(--text)}
  .insight-box.warn{border-left-color:var(--accent4)}
  .insight-box.ok{border-left-color:var(--positive)}
  section-title{display:block;font-size:12px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:12px}
  @media(max-width:900px){.grid-2,.grid-3,.grid-2-1{grid-template-columns:1fr}.pricing-grid{grid-template-columns:1fr 1fr}.kpi-row{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>
<header>
  <h1>📊 WebMD Directory — Revenue Intelligence</h1>
  <span>Data through Feb 2026</span>
</header>
<nav>
  <button class="active" onclick="showPage('overview',this)">Overview</button>
  <button onclick="showPage('mrr',this)">MRR Roll Forward</button>
  <button onclick="showPage('cohorts',this)">Cohort Retention</button>
  <button onclick="showPage('segments',this)">Segments & ARPC</button>
  <button onclick="showPage('aops',this)">AOPs</button>
  <button onclick="showPage('contacts',this)">Contacts & DPC</button>
  <button onclick="showPage('pricing',this)">💡 Pricing Strategy</button>
</nav>

<!-- OVERVIEW -->
<div class="page active" id="page-overview">
  <div class="kpi-row" id="kpis"></div>
  <div class="grid grid-2" style="margin-bottom:16px">
    <div class="card">
      <div class="card-title">Monthly Recurring Revenue <span>EP + Telemed + RepMn, monthly billing</span></div>
      <canvas id="chart-mrr-main" height="200"></canvas>
    </div>
    <div class="card">
      <div class="card-title">MRR Waterfall — Last 12 Months <span>New / Expansion / Contraction / Churn</span></div>
      <canvas id="chart-waterfall-bar" height="200"></canvas>
    </div>
  </div>
  <div class="grid grid-3">
    <div class="card">
      <div class="card-title">Annual Total Churn Rate <span>(Cancels + Contraction) ÷ Starting MRR × 12</span></div>
      <canvas id="chart-churn-line" height="180"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Active EP Profiles & Accounts <span>Monthly billing only</span></div>
      <canvas id="chart-accounts" height="180"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Rev per Profile & per Account (EP) <span>Monthly billing</span></div>
      <canvas id="chart-arpc" height="180"></canvas>
    </div>
  </div>
</div>

<!-- MRR -->
<div class="page" id="page-mrr">
  <div class="kpi-row" id="mrr-kpis"></div>
  <div class="grid grid-2" style="margin-bottom:16px">
    <div class="card">
      <div class="card-title">Full MRR Waterfall <span>All months</span></div>
      <canvas id="chart-wf-stacked" height="260"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Revenue by Product <span>Monthly billing</span></div>
      <canvas id="chart-by-product" height="260"></canvas>
    </div>
  </div>
  <div class="card">
    <div class="card-title">MRR Roll Forward Detail</div>
    <div class="table-wrap">
      <table><thead><tr><th>Month</th><th>Starting MRR</th><th>New MRR</th><th>Expansion</th><th>Contraction</th><th>Churned</th><th>Ending MRR</th><th>Net Δ</th><th>Annual Total Churn %</th></tr></thead>
      <tbody id="mrr-table-body"></tbody></table>
    </div>
  </div>
</div>

<!-- COHORTS -->
<div class="page" id="page-cohorts">
  <div class="filter-bar">
    <label>Show cohorts from:</label>
    <select id="cohort-from" onchange="renderCohorts()">
      <option value="all">All cohorts</option>
      <option value="2023">2023</option>
      <option value="2024" selected>2024+</option>
      <option value="2025">2025+</option>
    </select>
  </div>
  <div class="card" style="margin-bottom:16px">
    <div class="card-title">Cohort Revenue Retention Heatmap <span>% of initial cohort MRR remaining at Month N</span></div>
    <div class="cohort-table" id="cohort-heatmap"></div>
  </div>
  <div class="card">
    <div class="card-title">Average Retention Curve <span>Across selected cohorts</span></div>
    <canvas id="chart-retention-avg" height="200"></canvas>
  </div>
</div>

<!-- SEGMENTS -->
<div class="page" id="page-segments">
  <div class="grid grid-2" style="margin-bottom:16px">
    <div class="card">
      <div class="card-title">Revenue by AOP Tier <span>EP monthly</span></div>
      <canvas id="chart-by-tier" height="240"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Revenue by ARPC Range <span>EP monthly — new dimension</span></div>
      <canvas id="chart-by-range" height="240"></canvas>
    </div>
  </div>
  <div class="grid grid-2" style="margin-bottom:16px">
    <div class="card">
      <div class="card-title">Enterprise vs Non-Enterprise <span>EP monthly revenue</span></div>
      <canvas id="chart-by-type" height="220"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Revenue by Tier — Feb 2026 <span>EP monthly active, profiles & accounts</span></div>
      <div class="table-wrap" style="margin-top:8px">
        <table><thead><tr><th>Tier</th><th>Profiles</th><th>Accounts</th><th>Revenue</th><th>$/Profile</th><th>$/Account</th><th>Share</th></tr></thead>
        <tbody id="tier-table-body"></tbody></table>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-title">ARPC by Price Range — Feb 2026 <span>Note: $0-$75 label = accounts with highest individual plan prices; range reflects billing tier not actual ARPC</span></div>
    <div class="table-wrap">
      <table><thead><tr><th>ARPC Range</th><th>Profiles</th><th>Accounts</th><th>Revenue</th><th>$/Profile</th><th>Share</th></tr></thead>
      <tbody id="range-table-body"></tbody></table>
    </div>
  </div>
</div>

<!-- AOPs -->
<div class="page" id="page-aops">
  <div class="card" style="margin-bottom:16px">
    <div class="card-title">Top 15 AOPs by 6M Revenue <span>EP monthly, last 6 months</span></div>
    <canvas id="chart-aops" height="340"></canvas>
  </div>
  <div class="card">
    <div class="card-title">Full AOP Table <span>Top 25 by revenue</span></div>
    <div class="table-wrap">
      <table><thead><tr><th>#</th><th>Area of Practice</th><th>6M Revenue</th><th>Profiles</th><th>Accounts</th><th>$/Profile/Mo</th></tr></thead>
      <tbody id="aop-table-body"></tbody></table>
    </div>
  </div>
</div>


<!-- CONTACTS -->
<div class="page" id="page-contacts">
  <div class="kpi-row" id="contacts-kpis"></div>

  <div class="grid grid-2" style="margin-bottom:16px">
    <div class="card">
      <div class="card-title">Monthly Contacts & Dollar per Contact (DPC) <span>EP monthly billing — Feb 2026 data pending</span></div>
      <canvas id="chart-contacts-ts" height="220"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Contacts per Profile Trend <span>vs Annual Total Churn Rate</span></div>
      <canvas id="chart-cpp-churn" height="220"></canvas>
    </div>
  </div>

  <div class="grid grid-2" style="margin-bottom:16px">
    <div class="card">
      <div class="card-title">Scatter: Contacts/Profile vs Annual Total Churn <span>Each point = 1 month (Jan 2023 – Jan 2026)</span></div>
      <canvas id="chart-scatter" height="260"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Dollar per Contact (DPC) by Segment <span>Jan 2026 — EP monthly active</span></div>
      <canvas id="chart-dpc-seg" height="260"></canvas>
    </div>
  </div>

  <div class="grid grid-2" style="margin-bottom:16px">
    <div class="card">
      <div class="card-title">DPC by AOP <span>Top 20 AOPs by revenue — Jan 2026</span></div>
      <canvas id="chart-dpc-aop" height="320"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Contacts & DPC by Segment — Jan 2026 <span>Non-Enterprise drives 100% of tracked contacts</span></div>
      <div class="table-wrap" style="margin-top:8px">
        <table>
          <thead><tr><th>Segment</th><th>Contacts</th><th>Profiles</th><th>Contacts/Profile</th><th>Revenue</th><th>DPC ($)</th></tr></thead>
          <tbody id="contacts-seg-table"></tbody>
        </table>
      </div>
      <div class="insight-box warn" style="margin-top:14px">
        <strong>⚠️ Enterprise Contact Data Missing — Confirmed:</strong> All 45 Enterprise accounts show exactly zero contacts across all 38 months of data. This is a systematic gap — not a monthly anomaly. Enterprise generates $178K/month (28% of EP revenue) but contributes 0 tracked contacts. The AOP demand classification and DPC analysis in the Pricing tab excludes Enterprise entirely and uses Non-Enterprise data only. Resolve tracking before any Enterprise-specific pricing or ROI conversations.
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Key Contacts Findings</div>
    <div class="grid grid-3" style="margin-top:4px">
      <div class="insight-box warn">
        <strong>Contacts declining sharply:</strong> Peak of ~30K/month in mid-2024 dropped to ~16K by Jun-Jul 2025 — a 45% decline. Even though revenue held up, this is a leading indicator of future churn risk. Physicians evaluate ROI by lead flow; fewer contacts = higher cancel probability.
      </div>
      <div class="insight-box">
        <strong>Correlation: contacts/profile vs annual churn = +0.40:</strong> Counterintuitively, months with MORE contacts/profile correlate with HIGHER churn. This likely reflects early-tenure accounts (many contacts, still learning the platform) canceling at higher rates. Mature, retained accounts have fewer but more valuable contacts.
      </div>
      <div class="insight-box ok">
        <strong>DPC rising is a double-edged signal:</strong> DPC has climbed from ~$19–22 in 2023–2024 to $32–45 in 2025. This means each contact is "worth" more — but it's driven by fewer contacts, not higher revenue. The $150–$300 ARPC range drives the most contacts (8.9/profile) and lowest DPC ($20.70), suggesting volume = efficiency.
      </div>
    </div>
  </div>
</div>

<!-- PRICING -->
<div class="page" id="page-pricing">
  <div style="margin-bottom:20px">
    <div style="font-size:16px;font-weight:700;margin-bottom:6px">💡 Per-Profile Pricing — Volume × AOP Demand Matrix</div>
    <div style="font-size:12px;color:var(--text2)">Price per profile per month based on two axes: (1) how many profiles the account brings, (2) how much contact demand the AOP generates. Volume drives the base rate down; AOP demand adjusts it up or down by 20%.</div>
  </div>

  <div class="insight-box warn" style="margin-bottom:16px">
    <strong>⚠️ Policy &amp; Data Note:</strong> New pricing applies to all new logos immediately. For existing accounts, rates only go <em>up</em> — 28 accounts already above target are held and reviewed at renewal.<br><br><strong>AOP demand classification uses Non-Enterprise accounts only.</strong> All 45 Enterprise accounts show zero contacts across all 38 months of data — their contact data is either tracked separately or not flowing into this dataset. Including them artificially suppresses CPP for 8 AOPs. Classification is based on Non-Enterprise CPP and $/profile only, which is the accurate signal.
  </div>

  <!-- PRICING MATRIX TABLE -->
  <div style="margin-bottom:20px">
    <section-title>THE 2D PRICING MATRIX — $/PROFILE/MO</section-title>
    <div class="card">
      <div style="font-size:11px;color:var(--text2);margin-bottom:10px">
        <span style="display:inline-block;width:12px;height:12px;background:rgba(52,211,153,0.3);border-radius:2px;margin-right:4px"></span>High demand (CPP ≥5 AND $/prof ≥$150) &nbsp;&nbsp;
        <span style="display:inline-block;width:12px;height:12px;background:rgba(79,142,247,0.2);border-radius:2px;margin-right:4px"></span>Standard demand &nbsp;&nbsp;
        <span style="display:inline-block;width:12px;height:12px;background:rgba(100,116,139,0.2);border-radius:2px;margin-right:4px"></span>Low demand &nbsp;&nbsp;
        <span style="color:var(--text3)">Bold = target rate · italic gray = accounts already above target (hold)</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Volume Bracket</th><th>Accts</th><th>Profiles</th>
              <th style="background:rgba(52,211,153,0.1);color:#34d399">High Demand AOP<br><span style="font-weight:400;font-size:10px">+20% premium</span></th>
              <th style="background:rgba(79,142,247,0.1);color:#4f8ef7">Standard Demand AOP<br><span style="font-weight:400;font-size:10px">base rate</span></th>
              <th style="background:rgba(100,116,139,0.1);color:#64748b">Low Demand AOP<br><span style="font-weight:400;font-size:10px">−20% discount</span></th>
              <th>MRR Uplift</th>
            </tr>
          </thead>
          <tbody id="pricing-matrix-tbody"></tbody>
        </table>
      </div>
      <div style="margin-top:10px;font-size:11px;color:var(--text3)">
        ↑ = raise to target &nbsp;|&nbsp; HOLD = already above target, grandfather at renewal &nbsp;|&nbsp; Annual pre-pay: 17% off all rates
      </div>
    </div>
  </div>

  <!-- AOP CLASSIFICATION -->
  <div style="margin-bottom:20px">
    <section-title>AOP DEMAND CLASSIFICATION <span style="font-size:10px;font-weight:400;color:var(--accent3)">Non-Enterprise only — Enterprise contacts missing from data</span></section-title>
    <div class="grid grid-3">
      <div class="card">
        <div class="card-title" style="color:#34d399">▲ High Demand <span>CPP ≥5 AND $/profile ≥$150</span></div>
        <div style="font-size:11px;line-height:1.9;color:var(--text2)" id="aop-high-list"></div>
        <div class="insight-box ok" style="margin-top:10px;font-size:11px">High contact volume <em>and</em> strong revenue per profile. These AOPs justify premium pricing on both axes.</div>
      </div>
      <div class="card">
        <div class="card-title" style="color:#4f8ef7">● Standard Demand <span>CPP ≥5 OR $/profile ≥$150</span></div>
        <div style="font-size:11px;line-height:1.9;color:var(--text2)" id="aop-std-list"></div>
        <div class="insight-box" style="margin-top:10px;font-size:11px">Strong on one dimension. Qualify for base rate — neither premium nor discounted.</div>
      </div>
      <div class="card">
        <div class="card-title" style="color:#64748b">▼ Low Demand <span>CPP &lt;5 AND $/profile &lt;$150</span></div>
        <div style="font-size:11px;line-height:1.9;color:var(--text2)" id="aop-low-list"></div>
        <div class="insight-box warn" style="margin-top:10px;font-size:11px">Lower contact volume and lower revenue per profile. Discounted rate reduces churn risk for these lower-ROI segments.</div>
      </div>
    </div>
  </div>

  <!-- VOLUME LADDER VISUAL -->
  <div style="margin-bottom:20px">
    <section-title>BASE RATE VOLUME LADDER</section-title>
    <div class="card">
      <div style="font-size:11px;color:var(--text2);margin-bottom:14px">Base rate before AOP adjustment. Each bracket shows 3 prices: Low / Standard / High demand.</div>
      <canvas id="chart-pricing-ladder" height="160"></canvas>
      <div style="margin-top:12px;display:grid;grid-template-columns:repeat(4,1fr);gap:10px;font-size:11px">
        <div class="insight-box" style="margin:0"><strong>Solo (1 profile):</strong><br>$160 / $199 / $240 per profile/mo<br>1,527 accounts · 84.6% of base</div>
        <div class="insight-box" style="margin:0"><strong>Group (3–5):</strong><br>$135 / $169 / $205 per profile/mo<br>76 accounts · adding profiles drops rate</div>
        <div class="insight-box" style="margin:0"><strong>Enterprise (51–200):</strong><br>$65 / $79 / $95 per profile/mo<br>10 accounts · annual contract required</div>
        <div class="insight-box" style="margin:0"><strong>Strategic (201+):</strong><br>$45 / $55 / $65 per profile/mo<br>3 accounts (DearDoc 940, Talkiatry 400, Methodist 253)</div>
      </div>
    </div>
  </div>

  <!-- REVENUE IMPACT -->
  <div style="margin-bottom:20px">
    <section-title>REVENUE IMPACT — RAISE-ONLY POLICY</section-title>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr>
            <th>Segment</th><th>Accts to Raise</th><th>Profiles</th>
            <th>Current MRR</th><th>Target MRR</th><th>Gross Uplift</th><th>Realistic (70%)</th>
          </tr></thead>
          <tbody id="impact-tbody"></tbody>
        </table>
      </div>
      <div style="margin-top:10px;font-size:11px;color:var(--text3)">
        Raise-only: 764 accounts already above target are excluded (HOLD). Realistic = 70% adoption accounting for churn from price increase and grandfathering. Does not include RepMn/Telemed add-on revenue.
      </div>
    </div>
  </div>

  <!-- ROLLOUT -->
  <div style="margin-bottom:20px">
    <section-title>ROLLOUT PLAN</section-title>
    <div class="grid grid-2">
      <div>
